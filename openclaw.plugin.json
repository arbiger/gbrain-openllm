{
  "name": "gbrain-openllm",
  "version": "0.12.0",
  "description": "GBrain fork with OpenClaw-style provider support - omlx primary LLM + cloud fallback",
  "family": "bundle-plugin",
  "configSchema": {
    "database_url": {
      "type": "string",
      "required": false,
      "description": "PostgreSQL connection URL (Supabase recommended)",
      "uiHints": { "sensitive": true }
    },
    "openai_api_key": {
      "type": "string",
      "required": false,
      "description": "OpenAI API key for embeddings fallback",
      "uiHints": { "sensitive": true }
    },
    "minimax_api_key": {
      "type": "string",
      "required": false,
      "description": "MiniMax API key for LLM fallback",
      "uiHints": { "sensitive": true }
    }
  },
  "mcpServers": {
    "gbrain-openllm": {
      "command": "./bin/gbrain",
      "args": ["serve"]
    }
  },
  "skills": [
    "skills/ingest",
    "skills/query",
    "skills/maintain",
    "skills/enrich",
    "skills/briefing",
    "skills/migrate",
    "skills/setup"
  ],
  "openclaw": {
    "compat": {
      "pluginApi": ">=2026.4.0"
    }
  }
}
